# TaskFlow backend environment template.
# Copy to .env and fill in real values. NEVER commit real secrets.
# TODO: Javier Lopez / Marco Rossi — expand with all Sprint 1 variables.

# Application
APP_NAME=TaskFlow
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL / Amazon RDS)
# TODO: Use AWS Secrets Manager in production instead of plaintext env.
DATABASE_URL=postgresql+asyncpg://taskflow:CHANGE_ME@localhost:5432/taskflow

# Redis (ElastiCache)
REDIS_URL=redis://localhost:6379/0

# JWT / Auth (placeholder — generate a strong secret in Secrets Manager)
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI / OpenAI (env-keyed, mocked in dev)
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4
AI_MOCK=true

# AWS (for deployment / S3 / Secrets Manager)
AWS_REGION=us-east-1
S3_BUCKET=CHANGE_ME
